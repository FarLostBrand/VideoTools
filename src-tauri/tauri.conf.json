{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VideoTools",
  "version": "1.1.1",
  "identifier": "com.videotools.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VideoTools",
        "width": 960,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../scripts/convert.py": "scripts/convert.py"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/FarLostBrand/VideoTools/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExMEY0NDEzNDJBMEYyRkIKUldUNzhxQkNFMFFQb2UxdkRwMzNqMENxVnBJb0d0WGtLTkNpV1kvajU4YmZYT2YrNHhmVXMrRDEK"
    }
  }
}
